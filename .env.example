# Root of the data lake. Local folder for native dev; /data/lake inside
# Docker; s3://... in production.
DATA_LAKE_PATH=data/lake

# DuckDB warehouse file written by dbt and read by the API/Metabase.
DUCKDB_PATH=data/warehouse.duckdb

# Optional: incoming webhook (Slack-style {"text": ...}) that receives an
# alert whenever a Dagster run fails. Leave unset to disable alerting.
ALERT_WEBHOOK_URL=
